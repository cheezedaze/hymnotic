# =============================================================================
# HYMNZ Environment Variables (Example)
# =============================================================================
# Copy this to .env.local and fill in your values

# AWS S3 - Media Storage
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-west-2
AWS_S3_BUCKET=hymnotic-media

# CloudFront CDN URL
NEXT_PUBLIC_CDN_URL=https://d1234567890.cloudfront.net

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# Auth.js (NextAuth v5)
AUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_URL=http://localhost:3333

# Resend (Emails & Newsletter)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=HYMNZ <noreply@yourdomain.com>
RESEND_AUDIENCE_ID=aud_xxxxxxxxxxxx

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3333

# Mobile app-install banner (web)
# When set, iOS Safari renders the native Smart App Banner via <meta apple-itunes-app>
# and Android Chrome shows a custom dismissible top banner linking to the Play Store.
# Leave unset until the apps are live; banners no-op when missing.
NEXT_PUBLIC_IOS_APP_ID=
NEXT_PUBLIC_ANDROID_PACKAGE=

# Google OAuth — web (used by NextAuth's web Google provider)
AUTH_GOOGLE_ID=your_web_google_client_id
AUTH_GOOGLE_SECRET=your_web_google_client_secret

# Google OAuth — native mobile audiences for /api/auth/mobile/google.
# Public client IDs (no secret). iOS-type and Android-type clients in Google Cloud.
# If using Play App Signing, register both upload-key and app-signing SHA fingerprints
# as separate Android OAuth clients in Google Cloud and list both IDs.
AUTH_GOOGLE_IOS_ID=your_ios_google_client_id
AUTH_GOOGLE_ANDROID_ID=your_android_google_client_id_app_signing
AUTH_GOOGLE_ANDROID_UPLOAD_ID=your_android_google_client_id_upload_key

# Apple Sign in with Apple
# AUTH_APPLE_ID = web Services ID (NOT App ID), e.g. com.hymnz.app.web
# AUTH_APPLE_SECRET = JSON string: {"teamId":"...","keyId":"...","privateKey":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"}
# AUTH_APPLE_NATIVE_AUD = App ID, used as audience for native iOS Sign In with Apple
AUTH_APPLE_ID=com.hymnz.app.web
AUTH_APPLE_SECRET=see_instructions_in_README
AUTH_APPLE_NATIVE_AUD=com.hymnz.app

# Public Google client IDs (exposed to client for SocialLogin.initialize on native)
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=same_value_as_AUTH_GOOGLE_ID
NEXT_PUBLIC_GOOGLE_IOS_CLIENT_ID=same_value_as_AUTH_GOOGLE_IOS_ID

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_YEARLY_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_INTRO_COUPON_ID=coupon_id_here
